# =============================================================================
# llm-companion.kube — Quadlet .kube unit for the llm-companion stack
#
# This Quadlet unit file replaces the individual .container/.network files.
# It manages the entire llm-companion pod (Ollama + Open WebUI + Caddy) via
# a single Kubernetes Pod manifest (stack.yml).
#
# Installation (Fedora / rootless Podman with Quadlet support):
#   # Ansible handles this automatically — manual steps for reference:
#   mkdir -p ~/.config/containers/systemd
#   cp llm-companion.kube ~/.config/containers/systemd/
#   cp stack.yml          ~/.config/containers/systemd/
#   # Generate secrets first (see ansible/roles/llm-stack/):
#   # podman play kube ~/.config/containers/systemd/llm-companion-secrets.yml
#   systemctl --user daemon-reload
#   systemctl --user enable --now llm-companion
#
# The secrets file (llm-companion-secrets.yml) is generated by Ansible and
# is NOT stored in git. It contains the Ollama API key and WebUI secret key.
# To apply manually:
#   podman play kube ~/.config/containers/systemd/llm-companion-secrets.yml
# =============================================================================

[Unit]
Description=llm-companion stack (Ollama + Open WebUI + Caddy)
Documentation=https://github.com/tprrt/llm-companion
After=network-online.target
Wants=network-online.target

[Kube]
# Path where Ansible copies stack.yml (the Kubernetes Pod manifest).
Yaml=%h/.config/containers/systemd/stack.yml

# Auto-update images when new versions are available via the registry.
AutoUpdate=registry

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=300
# Apply the secrets Kubernetes Secret YAML before starting the pod.
# llm-companion-secrets.yml is generated by Ansible (not in git).
# It must be applied before the pod starts so that the Secret exists
# when Podman tries to resolve the secretKeyRef env vars.
ExecStartPre=/usr/bin/podman play kube %h/.config/containers/systemd/llm-companion-secrets.yml

[Install]
WantedBy=default.target
