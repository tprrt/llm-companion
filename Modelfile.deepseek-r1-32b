# =============================================================================
# Modelfile.deepseek-r1-32b — DeepSeek-R1 32B with 32k context
#
# TARGET: NVIDIA CUDA host with ≥ 20 GB VRAM (e.g. RTX 3090 / 4090, A5000).
# This model WILL NOT fit on a GPU with less than 20 GB VRAM.
#
# Memory guide (Q4_K_M, ≈ 20 GB base):
#   16k ctx → ~22 GB total  → needs 24 GB VRAM
#   32k ctx → ~24 GB total  → needs 24 GB VRAM (tight on 24 GB cards)
#
# Create with:
#   podman cp Modelfile.deepseek-r1-32b ollama:/tmp/
#   podman exec -it ollama ollama create deepseek-r1-32b-32k \
#       -f /tmp/Modelfile.deepseek-r1-32b
# =============================================================================

FROM deepseek-r1:32b

# 32k context gives chain-of-thought reasoning room without truncating
# intermediate steps. Drop to 16384 if you hit OOM.
PARAMETER num_ctx 32768

# Slight warmth for creative reasoning; keep low enough for factual answers.
PARAMETER temperature 0.15
