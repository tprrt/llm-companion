# Example inventory — copy to hosts.yml and fill in your hosts.
---
all:
  children:
    llm_companion:
      hosts:
        my-server:
          ansible_host: 192.168.1.100
          ansible_user: fedora          # or 'debian', 'ubuntu', your user
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
